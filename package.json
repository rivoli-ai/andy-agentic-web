{
  "name": "agentic-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "sh -c 'PIDS=$(lsof -tiTCP:4200 -sTCP:LISTEN 2>/dev/null); [ -n \"$PIDS\" ] && kill -9 $PIDS 2>/dev/null || true; exec ng serve'",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:ci": "jest --ci --coverage --maxWorkers=50%",
    "test:watch": "jest --watch",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.19",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.19",
    "@angular/compiler": "^19.2.19",
    "@angular/core": "^19.2.19",
    "@angular/forms": "^19.2.19",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.2.19",
    "@angular/platform-browser-dynamic": "^19.2.19",
    "@angular/router": "^19.2.19",
    "@azure/msal-angular": "^4.1.1",
    "@azure/msal-browser": "^4.30.0",
    "@microsoft/signalr": "^10.0.0",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "clipboard": "^2.0.11",
    "marked": "^15.0.7",
    "mermaid": "^11.6.0",
    "ngx-markdown": "^19.1.1",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "tailwindcss": "^3.4.17",
    "tslib": "^2.8.1",
    "uuidv4": "^6.2.13",
    "zone.js": "~0.15.0"
  },
  "overrides": {
    "@azure/msal-common": "15.17.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.19",
    "@angular-eslint/eslint-plugin": "^19.0.0",
    "@angular-eslint/eslint-plugin-template": "^19.0.0",
    "@angular-eslint/template-parser": "^19.0.0",
    "@angular/cli": "^19.2.19",
    "@angular/compiler-cli": "^19.2.19",
    "@types/jest": "^29.5.14",
    "@types/marked": "^6.0.0",
    "@types/node": "^20.0.0",
    "@types/prismjs": "^1.26.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.5.3",
    "lint-staged": "^13.0.0",
    "postcss": "^8.4.49",
    "prettier": "^2.8.8",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  }
}
